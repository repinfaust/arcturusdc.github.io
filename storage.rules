rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Super admins (mirror of Firestore rules). Custom claim primary; email
    // fallback transitional until claim removal there too.
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.superadmin == true ||
        request.auth.token.email == 'repinfaust@gmail.com' ||
        request.auth.token.email == 'daryn.shaxted@gmail.com'
      );
    }

    // Tenant membership check, mirroring the Firestore tenant_members model
    // (membershipId = email + '_' + tenantId, status == 'active'). Storage rules
    // CAN read Firestore via firestore.get(). This is the boundary that was
    // missing — paths are tenantId-keyed but were previously open to any
    // authenticated user, exposing every tenant's assets/files/specs cross-tenant.
    function inTenant(tenantId) {
      return isAuthenticated() && firestore.exists(
        /databases/(default)/documents/tenant_members/$(request.auth.token.email + '_' + tenantId)
      ) && firestore.get(
        /databases/(default)/documents/tenant_members/$(request.auth.token.email + '_' + tenantId)
      ).data.status == 'active';
    }

    function canAccessTenant(tenantId) {
      return isSuperAdmin() || inTenant(tenantId);
    }

    // Ruby document assets — tenant-scoped (membership verified via Firestore).
    match /ruby-assets/{tenantId}/{docId}/{fileName} {
      allow read: if canAccessTenant(tenantId);

      allow write: if canAccessTenant(tenantId)
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf|text/.*|application/json');

      allow delete: if canAccessTenant(tenantId);
    }

    // TLDraw whiteboard snapshots for Harls
    match /tldraw/{projectId}/{boardId}/{fileName} {
      // Allow authenticated users to read TLDraw snapshots
      // Access control is enforced at the Firestore project level
      allow read: if isAuthenticated();

      // Allow authenticated users to write TLDraw snapshots with size/type validation
      allow write: if isAuthenticated()
                   && request.resource.contentType == 'application/json'
                   && request.resource.size < 50 * 1024 * 1024; // 50MB limit for large whiteboards
    }

    // R7: API Specs — tenant-scoped (membership verified via Firestore).
    match /ruby/r7/api-specs/{tenantId}/{specId}/{fileName} {
      allow read: if canAccessTenant(tenantId);

      allow write: if canAccessTenant(tenantId)
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType == 'application/json'
                       || request.resource.contentType == 'application/yaml'
                       || request.resource.contentType == 'text/yaml');

      allow delete: if canAccessTenant(tenantId);
    }

    // R7: Figma Assets - Component thumbnails and previews
    match /ruby/r7/figma/{tenantId}/{fileId}/{allPaths=**} {
      // Read tenant-scoped; writes/deletes are server/MCP only (already denied).
      allow read: if canAccessTenant(tenantId);

      // Only server/MCP can write Figma assets (synced from Figma API)
      // Users cannot upload directly to Figma paths
      allow write: if false;

      // Only server can delete
      allow delete: if false;
    }

    // Ruby imported files - raw file storage — tenant-scoped.
    match /ruby-files/{tenantId}/{docId}/{fileName} {
      allow read: if canAccessTenant(tenantId);
      allow write: if canAccessTenant(tenantId)
                   && request.resource.size < 50 * 1024 * 1024; // 50MB limit
      allow delete: if canAccessTenant(tenantId);
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
